# Backend URL (your Express server)
VITE_BACKEND_URL=http://localhost:3001

# PayMongo public key (from PayMongo dashboard → Developers → API Keys)
VITE_PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
