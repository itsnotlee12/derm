# PayMongo secret key (from PayMongo dashboard → Developers → API Keys)
PAYMONGO_SECRET_KEY=your_paymongo_secret_key_here

# Webhook secret (from PayMongo dashboard → Developers → Webhooks)
PAYMONGO_WEBHOOK_SECRET=your_paymongo_webhook_secret_here

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Port
PORT=3001
